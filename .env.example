# HDX 本地开发环境变量示例。
# 复制为 .env.local 后填写真实本机配置；.env.local 不提交。

# 后端 service profile 启动引导与密钥。
# 非密钥运行配置放 Nacos Data ID，示例见 docs/config/nacos/。
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_USERNAME=
NACOS_PASSWORD=
HDX_NACOS_GROUP=DEFAULT_GROUP
HDX_NACOS_DATABASE_DATA_ID=hdx-database.yml
HDX_NACOS_AUTH_DATA_ID=hdx-auth-service.yml
HDX_NACOS_CORE_DATA_ID=hdx-core-service.yml
HDX_NACOS_GATEWAY_DATA_ID=hdx-gateway.yml
HDX_NACOS_REDIS_DATA_ID=hdx-redis.yml
HDX_NACOS_DISCOVERY_IP=
HDX_POSTGRES_PASSWORD=change-me
# 默认各模块共用 HDX_POSTGRES_PASSWORD；需要单独数据库账号时，在真实环境中设置下面任一变量。
# HDX_AUTH_POSTGRES_PASSWORD=change-me
# HDX_CORE_POSTGRES_PASSWORD=change-me

# Redis。用于 JWT 会话撤销/黑名单。
HDX_REDIS_HOST=127.0.0.1
HDX_REDIS_PORT=6379
HDX_REDIS_DATABASE=0
HDX_REDIS_PASSWORD=change-me

# desktop all-in-one 本地数据库。默认 H2 文件库通常不需要改。
HDX_LOCAL_JDBC_URL=jdbc:h2:file:./data/hdx-all-in-one;MODE=PostgreSQL;AUTO_SERVER=TRUE
HDX_LOCAL_DB_USERNAME=sa
HDX_LOCAL_DB_PASSWORD=

# Web / Nuxt server 私有 runtimeConfig。
# 浏览器代码不要直接读取真实后端地址。
HDX_BACKEND_BASE_URL=http://localhost:18080
NUXT_BACKEND_BASE_URL=http://localhost:18080
NUXT_BACKEND_LOCAL_TOKEN_HEADER=X-HDX-Local-Token
NUXT_BACKEND_LOCAL_TOKEN=
