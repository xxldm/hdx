# Symphony 本地环境变量示例。
# 复制为 .env.symphony.local 后填写真实本机配置；.env.symphony.local 不提交。

# 后端 service profile 使用的 PostgreSQL 与 Nacos。
HDX_POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/hdx
HDX_POSTGRES_USERNAME=hdx
HDX_POSTGRES_PASSWORD=change-me
NACOS_SERVER_ADDR=127.0.0.1:8848
HDX_JWT_ISSUER_URI=http://127.0.0.1:18080

# desktop all-in-one 本地数据库。默认 H2 文件库通常不需要改。
HDX_LOCAL_JDBC_URL=jdbc:h2:file:./data/hdx-all-in-one;MODE=PostgreSQL;AUTO_SERVER=TRUE
HDX_LOCAL_DB_USERNAME=sa
HDX_LOCAL_DB_PASSWORD=
