# Symphony 本地环境变量示例。
# 复制为 .env.symphony.local 后填写 Symphony 专用配置；.env.symphony.local 不提交。
# 通用本地配置放 .env.local；Symphony 启动脚本会先读取 .env.local，再读取 .env.symphony.local。

# Linear API Key 也可以继续放在 start-symphony.local.ps1 中；推荐后续改为由本文件注入。
LINEAR_API_KEY=lin_api_change_me

# 如确实需要让 Symphony 覆盖通用本地配置，可以在这里放同名变量。
# HDX_BACKEND_BASE_URL=http://localhost:18080
# HDX_NACOS_GROUP=DEFAULT_GROUP
