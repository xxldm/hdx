{
  "auth-service": {
    "AuthLoginRequest": {
      "required": ["identifier", "password"],
      "properties": {
        "identifier": { "type": "string", "maxLength": 320 },
        "password": { "type": "string", "maxLength": 200 },
        "clientType": { "type": "string", "maxLength": 30 }
      }
    },
    "AuthRefreshRequest": {
      "required": ["refreshToken"],
      "properties": {
        "refreshToken": { "type": "string", "maxLength": 200 }
      }
    },
    "AuthLogoutRequest": {
      "required": ["refreshToken"],
      "properties": {
        "refreshToken": { "type": "string", "maxLength": 200 }
      }
    },
    "AuthTokenResponse": {
      "properties": {
        "tokenType": { "type": "string" },
        "accessToken": { "type": "string" },
        "accessTokenExpiresAt": { "type": "string", "format": "date-time" },
        "refreshToken": { "type": "string" },
        "refreshTokenExpiresAt": { "type": "string", "format": "date-time" },
        "sid": { "type": "string" },
        "user": { "$ref": "#/components/schemas/AuthUserResponse" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "AuthUserResponse": {
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "displayName": { "type": "string" }
      }
    }
  },
  "gateway": {
    "RuntimeInfoResponse": {
      "required": ["application", "topology", "javaVersion", "nativeImage"],
      "properties": {
        "application": { "type": "string" },
        "topology": { "type": "string" },
        "javaVersion": { "type": "string" },
        "nativeImage": { "type": "boolean" }
      }
    },
    "CurrentActorResponse": {
      "required": ["actorType", "subject", "displayName", "roles", "permissions"],
      "properties": {
        "actorType": { "type": "string", "enum": ["USER", "LOCAL_ADMIN"] },
        "subject": { "type": "string" },
        "displayName": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ToolRecordResponse": {
      "required": ["id", "toolKey", "displayName", "description", "enabled", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "toolKey": { "type": "string", "maxLength": 80 },
        "displayName": { "type": "string", "maxLength": 120 },
        "description": { "type": "string", "maxLength": 500 },
        "enabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreateToolRequest": {
      "required": ["toolKey", "displayName"],
      "properties": {
        "toolKey": { "type": "string", "maxLength": 80 },
        "displayName": { "type": "string", "maxLength": 120 },
        "description": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
