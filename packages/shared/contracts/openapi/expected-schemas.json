{
  "auth-service": {
    "AuthLoginRequest": {
      "required": ["identifier", "password"],
      "properties": {
        "identifier": { "type": "string", "maxLength": 320 },
        "password": { "type": "string", "maxLength": 200 },
        "clientType": { "type": "string", "maxLength": 30 }
      }
    },
    "AuthRefreshRequest": {
      "required": ["refreshToken"],
      "properties": {
        "refreshToken": { "type": "string", "maxLength": 200 }
      }
    },
    "AuthLogoutRequest": {
      "required": ["refreshToken"],
      "properties": {
        "refreshToken": { "type": "string", "maxLength": 200 }
      }
    },
    "AuthTokenResponse": {
      "required": [
        "tokenType",
        "accessToken",
        "accessTokenExpiresAt",
        "refreshToken",
        "refreshTokenExpiresAt",
        "sid",
        "user",
        "roles",
        "permissions"
      ],
      "properties": {
        "tokenType": { "type": "string", "enum": ["Bearer"] },
        "accessToken": { "type": "string" },
        "accessTokenExpiresAt": { "type": "string", "format": "date-time" },
        "refreshToken": { "type": "string" },
        "refreshTokenExpiresAt": { "type": "string", "format": "date-time" },
        "sid": { "type": "string" },
        "user": { "$ref": "#/components/schemas/AuthUserResponse" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "AuthUserResponse": {
      "required": ["id", "displayName"],
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "displayName": { "type": "string" }
      }
    },
    "AuthSigningKeyResponse": {
      "required": ["keyId", "status", "activatedAt"],
      "properties": {
        "keyId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "RETIRED"] },
        "activatedAt": { "type": "string", "format": "date-time" },
        "retiredAt": { "type": "string", "format": "date-time" }
      }
    },
    "AuthSigningKeyRotationResponse": {
      "required": ["activeKey", "retiredKey", "usableKeys"],
      "properties": {
        "activeKey": { "$ref": "#/components/schemas/AuthSigningKeyResponse" },
        "retiredKey": { "$ref": "#/components/schemas/AuthSigningKeyResponse" },
        "usableKeys": {
          "type": "array",
          "items": { "$ref": "#/components/schemas/AuthSigningKeyResponse" }
        }
      }
    },
    "ApiErrorResponse": {
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  },
  "gateway": {
    "RuntimeInfoResponse": {
      "required": ["application", "topology", "javaVersion", "nativeImage"],
      "properties": {
        "application": { "type": "string" },
        "topology": { "type": "string" },
        "javaVersion": { "type": "string" },
        "nativeImage": { "type": "boolean" }
      }
    },
    "CurrentActorResponse": {
      "required": ["actorType", "subject", "displayName", "roles", "permissions"],
      "properties": {
        "actorType": { "type": "string", "enum": ["USER", "LOCAL_ADMIN"] },
        "subject": { "type": "string" },
        "displayName": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ToolRecordResponse": {
      "required": ["id", "toolKey", "displayName", "enabled", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "toolKey": { "type": "string", "maxLength": 80 },
        "displayName": { "type": "string", "maxLength": 120 },
        "description": { "type": "string", "maxLength": 500, "nullable": true },
        "enabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreateToolRequest": {
      "required": ["toolKey", "displayName"],
      "properties": {
        "toolKey": { "type": "string", "maxLength": 80 },
        "displayName": { "type": "string", "maxLength": 120 },
        "description": { "type": "string", "maxLength": 500 }
      }
    },
    "TimerPreferencePresetRequest": {
      "required": ["id", "order", "durationSeconds"],
      "properties": {
        "id": { "type": "string", "maxLength": 120 },
        "order": { "type": "integer", "format": "int32" },
        "durationSeconds": { "type": "integer", "format": "int32" }
      }
    },
    "TimerPreferencePresetResponse": {
      "required": ["id", "order", "durationSeconds", "createdAt"],
      "properties": {
        "id": { "type": "string", "maxLength": 120 },
        "order": { "type": "integer", "format": "int32" },
        "durationSeconds": { "type": "integer", "format": "int32" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TimerPreferenceSaveRequest": {
      "required": ["schemaVersion", "version", "presets"],
      "properties": {
        "schemaVersion": { "type": "integer", "format": "int32" },
        "version": { "type": "integer", "format": "int32" },
        "presets": {
          "type": "array",
          "items": { "$ref": "#/components/schemas/TimerPreferencePresetRequest" }
        }
      }
    },
    "TimerPreferenceResponse": {
      "required": ["schemaVersion", "version", "presets"],
      "properties": {
        "schemaVersion": { "type": "integer", "format": "int32" },
        "version": { "type": "integer", "format": "int32" },
        "presets": {
          "type": "array",
          "items": { "$ref": "#/components/schemas/TimerPreferencePresetResponse" }
        }
      }
    },
    "TimerPreferenceConflictResponse": {
      "required": ["code", "message", "resourceType", "baseVersion", "currentVersion", "updatedAt", "updatedByUserId", "serverPreference"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "resourceType": { "type": "string" },
        "baseVersion": { "type": "integer", "format": "int32" },
        "currentVersion": { "type": "integer", "format": "int32" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedByUserId": { "type": "string", "maxLength": 160 },
        "serverPreference": { "$ref": "#/components/schemas/TimerPreferenceResponse" }
      }
    },
    "ApiErrorResponse": {
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
