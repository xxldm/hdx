{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdx.example/contracts/release/backend-build.schema.json",
  "title": "HDX Desktop Full Backend Build",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestKind",
    "version",
    "generatedAt",
    "root",
    "desktop",
    "backend"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestKind": {
      "const": "backend-build"
    },
    "version": {
      "$ref": "#/$defs/releaseVersion"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "$ref": "#/$defs/rootRef"
    },
    "desktop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "flavor",
        "platform"
      ],
      "properties": {
        "commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "flavor": {
          "const": "full"
        },
        "platform": {
          "enum": [
            "windows-x64",
            "linux-x64"
          ]
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "commit",
        "archiveFileName",
        "archiveSha256",
        "manifestSha256",
        "executablePath"
      ],
      "properties": {
        "kind": {
          "const": "backend-full"
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "archiveFileName": {
          "type": "string",
          "pattern": "^hdx-backend-full-(windows|linux)-x64-v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?\\.(zip|tar\\.gz)$",
          "not": {
            "pattern": "latest"
          }
        },
        "archiveSha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifestSha256": {
          "$ref": "#/$defs/sha256"
        },
        "executablePath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "not": {
        "pattern": "latest"
      }
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "rootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    }
  }
}
