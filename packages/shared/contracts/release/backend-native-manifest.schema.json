{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdx.example/contracts/release/backend-native-manifest.schema.json",
  "title": "HDX Backend Native Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestKind",
    "version",
    "generatedAt",
    "root",
    "backend",
    "githubActions",
    "openapiSnapshotHash",
    "forbiddenFilesScan",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestKind": {
      "const": "backend-native"
    },
    "version": {
      "$ref": "#/$defs/releaseVersion"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "$ref": "#/$defs/rootRef"
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit",
        "sourceVisibility"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "sourceVisibility": {
          "const": "private"
        }
      }
    },
    "githubActions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow",
        "runId",
        "runAttempt",
        "artifactName"
      ],
      "properties": {
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "runId": {
          "type": "integer",
          "minimum": 1
        },
        "runAttempt": {
          "type": "integer",
          "minimum": 1
        },
        "artifactName": {
          "type": "string",
          "minLength": 1
        },
        "artifactId": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "githubActionsArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "platform",
          "githubActions"
        ],
        "properties": {
          "kind": {
            "enum": [
              "backend-full",
              "backend-services"
            ]
          },
          "platform": {
            "enum": [
              "windows-x64",
              "linux-x64"
            ]
          },
          "githubActions": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workflow",
              "runId",
              "runAttempt",
              "artifactName"
            ],
            "properties": {
              "workflow": {
                "type": "string",
                "minLength": 1
              },
              "runId": {
                "type": "integer",
                "minimum": 1
              },
              "runAttempt": {
                "type": "integer",
                "minimum": 1
              },
              "artifactName": {
                "type": "string",
                "minLength": 1
              },
              "artifactId": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "openapiSnapshotHash": {
      "$ref": "#/$defs/sha256"
    },
    "forbiddenFilesScan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scannerVersion",
        "checkedPatterns"
      ],
      "properties": {
        "status": {
          "const": "passed"
        },
        "scannerVersion": {
          "type": "string",
          "minLength": 1
        },
        "checkedPatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nativeArtifact"
      }
    }
  },
  "$defs": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "not": {
        "pattern": "latest"
      }
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "rootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "nativeArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "platform",
        "fileName",
        "packaging",
        "sha256",
        "sizeBytes"
      ],
      "properties": {
        "kind": {
          "enum": [
            "backend-full",
            "backend-services"
          ]
        },
        "platform": {
          "enum": [
            "windows-x64",
            "linux-x64"
          ]
        },
        "fileName": {
          "type": "string",
          "pattern": "^hdx-backend-(full|services)-(windows|linux)-x64-v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?\\.(zip|tar\\.gz)$",
          "not": {
            "pattern": "latest"
          }
        },
        "packaging": {
          "enum": [
            "zip",
            "tar.gz"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "entrypoints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
