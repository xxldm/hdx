{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdx.example/contracts/release/backend-services-manifest.schema.json",
  "title": "HDX Backend Services Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestKind",
    "version",
    "generatedAt",
    "root",
    "backend",
    "platform",
    "services",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestKind": {
      "const": "backend-services"
    },
    "version": {
      "$ref": "#/$defs/releaseVersion"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "$ref": "#/$defs/rootRef"
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "platform": {
      "enum": [
        "windows-x64",
        "linux-x64"
      ]
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/packageFile"
      }
    }
  },
  "$defs": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "not": {
        "pattern": "latest"
      }
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "rootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "executablePath",
        "exposure"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^hdx-[a-z0-9-]+$"
        },
        "executablePath": {
          "type": "string",
          "pattern": "^bin/"
        },
        "configExamplePath": {
          "type": "string",
          "pattern": "^config/"
        },
        "exposure": {
          "enum": [
            "external",
            "internal"
          ]
        },
        "healthCheckPath": {
          "type": "string",
          "pattern": "^/"
        }
      }
    },
    "packageFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "sizeBytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
