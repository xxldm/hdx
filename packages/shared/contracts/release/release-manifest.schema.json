{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdx.example/contracts/release/release-manifest.schema.json",
  "title": "HDX Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestKind",
    "version",
    "generatedAt",
    "root",
    "sources",
    "openapiSnapshotHash",
    "backendNativeManifest",
    "assets"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestKind": {
      "const": "release"
    },
    "version": {
      "$ref": "#/$defs/releaseVersion"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "$ref": "#/$defs/rootRef"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend"
      ],
      "properties": {
        "web": {
          "$ref": "#/$defs/sourceRef"
        },
        "desktop": {
          "$ref": "#/$defs/sourceRef"
        },
        "android": {
          "$ref": "#/$defs/sourceRef"
        },
        "harmonyos": {
          "$ref": "#/$defs/sourceRef"
        },
        "backend": {
          "$ref": "#/$defs/sourceRef"
        }
      }
    },
    "openapiSnapshotHash": {
      "$ref": "#/$defs/sha256"
    },
    "backendNativeManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileName",
        "sha256",
        "backendCommit",
        "source"
      ],
      "properties": {
        "fileName": {
          "const": "backend-native-manifest.json"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "backendCommit": {
          "$ref": "#/$defs/gitCommit"
        },
        "source": {
          "$ref": "#/$defs/backendNativeManifestSource"
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/releaseAsset"
      }
    }
  },
  "$defs": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "not": {
        "pattern": "latest"
      }
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "rootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "githubActionsSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow",
        "runId",
        "runAttempt",
        "artifactName"
      ],
      "properties": {
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "runId": {
          "type": "integer",
          "minimum": 1
        },
        "runAttempt": {
          "type": "integer",
          "minimum": 1
        },
        "artifactName": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "artifactId": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "historicalReleaseAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "assetName",
        "assetSha256",
        "assetSizeBytes",
        "releaseManifestSha256"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "$ref": "#/$defs/releaseVersion"
        },
        "assetName": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "assetSha256": {
          "$ref": "#/$defs/sha256"
        },
        "assetSizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "releaseManifestSha256": {
          "$ref": "#/$defs/sha256"
        },
        "backendNativeManifestSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "historicalBackendBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "backend",
        "openapiSnapshotHash",
        "backendNativeManifestSha256"
      ],
      "properties": {
        "root": {
          "$ref": "#/$defs/rootRef"
        },
        "backend": {
          "$ref": "#/$defs/sourceRef"
        },
        "openapiSnapshotHash": {
          "$ref": "#/$defs/sha256"
        },
        "backendNativeManifestSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "backendNativeManifestSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "github-actions-artifact",
            "historical-release-asset"
          ]
        },
        "githubActions": {
          "$ref": "#/$defs/githubActionsSource"
        },
        "historicalRelease": {
          "$ref": "#/$defs/historicalReleaseAsset"
        },
        "historicalBuild": {
          "$ref": "#/$defs/historicalBackendBuild"
        },
        "backendNativeFingerprint": {
          "$ref": "#/$defs/backendNativeFingerprint"
        }
      }
    },
    "backendNativeFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "sha256",
        "backend",
        "artifact",
        "openapiSnapshotHash",
        "packaging",
        "runtime",
        "nativeInputs"
      ],
      "properties": {
        "algorithm": {
          "const": "hdx-backend-native-fingerprint-v1"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "backend": {
          "$ref": "#/$defs/sourceRef"
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "platform",
            "packaging"
          ],
          "properties": {
            "kind": {
              "enum": [
                "backend-full",
                "backend-services"
              ]
            },
            "platform": {
              "enum": [
                "windows-x64",
                "linux-x64"
              ]
            },
            "packaging": {
              "enum": [
                "zip",
                "tar.gz"
              ]
            },
            "entrypoints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "module",
              "executablePath"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^hdx-[a-z0-9-]+$"
              },
              "module": {
                "type": "string",
                "minLength": 1
              },
              "executablePath": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "uniqueItems": true
        },
        "openapiSnapshotHash": {
          "$ref": "#/$defs/sha256"
        },
        "packaging": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "manifestSchemaVersion",
            "packagingScriptVersion"
          ],
          "properties": {
            "manifestSchemaVersion": {
              "type": "string",
              "minLength": 1
            },
            "packagingScriptVersion": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "javaVersion",
            "graalvmVersion"
          ],
          "properties": {
            "javaVersion": {
              "type": "string",
              "minLength": 1
            },
            "graalvmVersion": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "nativeInputs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mavenProfile",
            "nativeImageArgs",
            "springAot",
            "runtimeHints",
            "reachabilityMetadata",
            "nativeMetadata"
          ],
          "properties": {
            "mavenProfile": {
              "type": "string",
              "minLength": 1
            },
            "nativeImageArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "springAot": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean"
                }
              }
            },
            "runtimeHints": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "reachabilityMetadata": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "nativeMetadata": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "releaseAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "fileName",
        "sha256",
        "sizeBytes",
        "source"
      ],
      "properties": {
        "kind": {
          "enum": [
            "web",
            "desktop-online",
            "desktop-full",
            "backend-full",
            "backend-services",
            "android-online",
            "harmonyos-online",
            "metadata"
          ]
        },
        "platform": {
          "enum": [
            "windows-x64",
            "linux-x64",
            "android",
            "harmonyos"
          ]
        },
        "fileName": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "latest"
          }
        },
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "commit"
          ],
          "properties": {
            "type": {
              "enum": [
                "root",
                "web",
                "desktop",
                "backend",
                "android",
                "harmonyos",
                "generated",
                "historical-release-asset"
              ]
            },
            "commit": {
              "$ref": "#/$defs/gitCommit"
            },
            "manifestSha256": {
              "$ref": "#/$defs/sha256"
            },
            "openapiSnapshotHash": {
              "$ref": "#/$defs/sha256"
            },
            "historicalRelease": {
              "$ref": "#/$defs/historicalReleaseAsset"
            },
            "historicalBuild": {
              "$ref": "#/$defs/historicalBackendBuild"
            },
            "backendNativeFingerprint": {
              "$ref": "#/$defs/backendNativeFingerprint"
            }
          }
        }
      }
    }
  }
}
